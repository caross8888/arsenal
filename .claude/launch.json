{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vercel Dev (API + Frontend)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vercel", "dev", "--cwd", "arsenal-dashboard"],
      "port": 3000
    },
    {
      "name": "Static Frontend (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "arsenal-dashboard/public"],
      "port": 8080
    }
  ]
}
